<odoo>
    <template id="portal_expense_form" name="Portal Expenses">
        <t t-call="website.layout">
            <div class="container mt-5 mb-5">
                <h2>Expense Request</h2>
                <form action="/my/expenses/submit" method="post" class="mt-4">
                  
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input type="text"
                            name="description"
                            class="form-control"
                            required="required"
                            placeholder="Hotel, Transport, Food etc"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <select name="product_id"
                            class="form-select"
                            required="required">
                            <t t-foreach="products" t-as="p">
                                <option t-att-value="p.id">
                                    <t t-esc="p.display_name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    <!-- Amount -->
                    <div class="mb-3">
                        <label class="form-label">Total Amount</label>
                        <input type="number" step="0.01" name="amount"
                               class="form-control" required/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Included Taxes</label>
                        <input type="text" class="form-control" value="0.00" disabled/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Employee</label>
                        <input type="text" class="form-control"
                               t-att-value="employee.name" disabled/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Paid By</label>
                        <select name="paid_by" class="form-select">
                            <option value="own_account">Employee (to reimburse)</option>
                            <option value="company_account">Company</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Expense Date</label>
                        <input type="date" name="expense_date"
                               t-att-value="today"
                               class="form-control"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Manager</label>
                        <select class="form-select" disabled>
                            <t t-foreach="managers" t-as="m">
                                <option>
                                    <t t-esc="m.name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    <!-- Submit -->
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">
                            Submit Expense
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>
</odoo>