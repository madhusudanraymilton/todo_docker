<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Sequence ─────────────────────────────────────────────── -->
    <record id="seq_hr_resign" model="ir.sequence">
        <field name="name">Employee Resignation</field>
        <field name="code">hr.resign</field>
        <field name="prefix">RES/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- ── List View ─────────────────────────────────────────────── -->
    <record id="hr_resign_list_view" model="ir.ui.view">
        <field name="name">hr.resign.list</field>
        <field name="model">hr.resign</field>
        <field name="arch" type="xml">
            <list decoration-success="state=='approved'"
                  decoration-danger="state=='rejected'"
                  decoration-warning="state in ['submitted','hr_review']"
                  decoration-muted="state=='cancelled'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="request_date"/>
                <field name="last_working_date"/>
                <field name="notice_period_days"/>
                <field name="state" widget="badge"
                       decoration-success="state=='approved'"
                       decoration-danger="state in ['rejected','cancelled']"
                       decoration-warning="state in ['submitted','hr_review']"/>
            </list>
        </field>
    </record>

    <!-- ── Form View ─────────────────────────────────────────────── -->
    <record id="hr_resign_form_view" model="ir.ui.view">
        <field name="name">hr.resign.form</field>
        <field name="model">hr.resign</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_hr_review" string="Start HR Review" type="object"
                            class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="hr.group_hr_user"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-success"
                            invisible="state != 'hr_review'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_reject" string="Reject" type="object"
                            class="btn-danger"
                            invisible="state not in ['submitted','hr_review']"
                            groups="hr.group_hr_manager"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ['approved','cancelled']"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ['cancelled','rejected']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,hr_review,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_employee"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-user">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Employee</span>
                                <span class="o_stat_value">
                                    <field name="employee_id" readonly="1" nolabel="1"/>
                                </span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Reference"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Employee Information">
                            <field name="employee_id"/>
                            <field name="request_date"/>
                        </group>
                        <group string="Resignation Details">
                            <field name="last_working_date"/>
                            <field name="notice_period_days"/>
                            <field name="pdf_template"/>
                        </group>
                    </group>
                    <group string="HR Processing" groups="hr.group_hr_user">
                        <group>
                            <field name="approved_by" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="rejection_reason"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Reason for Resignation">
                            <field name="reason"
                                   placeholder="Employee's reason for resignation..."/>
                        </page>
                        <page string="Handover Notes">
                            <field name="additional_notes"
                                   placeholder="Handover plan, pending tasks..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Search View ───────────────────────────────────────────── -->
    <record id="hr_resign_search_view" model="ir.ui.view">
        <field name="name">hr.resign.search</field>
        <field name="model">hr.resign</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Reference"/>
                <field name="employee_id" string="Employee"/>
                <filter string="Submitted" name="submitted"
                        domain="[('state','=','submitted')]"/>
                <filter string="Under Review" name="hr_review"
                        domain="[('state','=','hr_review')]"/>
                <filter string="Approved" name="approved"
                        domain="[('state','=','approved')]"/>
                <filter string="Rejected" name="rejected"
                        domain="[('state','=','rejected')]"/>
                <filter string="Group by Status" name="group_state"
                        context="{'group_by':'state'}"/>
                <filter string="Group by Department" name="group_dept"
                        context="{'group_by':'department_id'}"/>
            </search>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────── -->
    <record id="action_hr_resign" model="ir.actions.act_window">
        <field name="name">Resignation Requests</field>
        <field name="res_model">hr.resign</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Backend menu (HR) ─────────────────────────────────────── -->
    <menuitem id="menu_hr_resign"
              name="Resignation Requests"
              parent="hr.menu_hr_root"
              action="action_hr_resign"
              sequence="30"
              groups="hr.group_hr_user"/>

</odoo>
