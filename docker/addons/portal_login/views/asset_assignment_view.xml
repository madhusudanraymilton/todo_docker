<odoo>


    <record id="view_asset_assignment_list" model="ir.ui.view">
        <field name="name">asset.assignment.list</field>
        <field name="model">asset.assignment</field>
        <field name="arch" type="xml">
            <list>
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="assign_date"/>
                <field name="return_date"/>
                <field name="duration"/>
            </list>
        </field>
    </record>



    <record id="view_asset_assignment_form" model="ir.ui.view">
        <field name="name">asset.assignment.form</field>
        <field name="model">asset.assignment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="asset_id"/>
                        <field name="employee_id"/>
                    </group>

                    <group>
                        <field name="assign_date"/>
                        <field name="return_date"/>
                        <field name="duration" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    
    <record id="action_asset_assignment" model="ir.actions.act_window">
        <field name="name">Asset Assignment</field>
        <field name="res_model">asset.assignment</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
