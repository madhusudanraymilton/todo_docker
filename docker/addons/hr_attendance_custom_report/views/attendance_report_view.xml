<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action for Custom Attendance List -->
    <record id="attendance_report_custom_action" model="ir.actions.act_window">
        <field name="name">Attendance Report</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="view_id" ref="hr_attendance_custom_report.hr_attendance_custom_list_view"/>
    </record>

    <!-- Menu under Reporting -> Attendance -->
    <menuitem
        id="attendance_report_menu_custom"
        name="Attendance List"
        parent="hr_attendance.menu_hr_attendance_reporting"
        action="attendance_report_custom_action"/>
</odoo>