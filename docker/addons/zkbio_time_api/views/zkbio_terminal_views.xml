<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ZKBio Terminal List View -->
    <record id="view_zkbio_terminal_list" model="ir.ui.view">
        <field name="name">zkbio.terminal.list</field>
        <field name="model">zkbio.terminal</field>
        <field name="arch" type="xml">
            <list string="Biometric Terminals" decoration-success="state == 'online'" decoration-muted="state == 'offline'" decoration-danger="state == 'error'">
                <field name="name"/>
                <field name="serial_number"/>
                <field name="ip_address"/>
                <field name="location"/>
                <field name="state" widget="badge" decoration-success="state == 'online'" decoration-muted="state == 'offline'" decoration-danger="state == 'error'"/>
                <field name="last_activity"/>
                <field name="config_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ZKBio Terminal Kanban View -->
    <record id="view_zkbio_terminal_kanban" model="ir.ui.view">
        <field name="name">zkbio.terminal.kanban</field>
        <field name="model">zkbio.terminal</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="serial_number"/>
                <field name="state"/>
                <field name="ip_address"/>
                <field name="location"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    <span class="o_kanban_record_subtitle">
                                        <field name="serial_number"/>
                                    </span>
                                </div>
                                <field name="state" widget="label_selection" options="{'classes': {'online': 'success', 'offline': 'warning', 'error': 'danger'}}"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="ip_address"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="location"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ZKBio Terminal Form View -->
    <record id="view_zkbio_terminal_form" model="ir.ui.view">
        <field name="name">zkbio.terminal.form</field>
        <field name="model">zkbio.terminal</field>
        <field name="arch" type="xml">
            <form string="Biometric Terminal">
                <header>
                    <button name="action_refresh_status" string="Refresh Status" type="object" class="btn-primary"/>
                    <button name="action_sync_attendance" string="Sync Attendance" type="object" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="online,offline"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Terminal Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Device Information">
                            <field name="serial_number"/>
                            <field name="terminal_id"/>
                            <field name="device_model"/>
                            <field name="firmware_version"/>
                        </group>
                        <group string="Network Information">
                            <field name="ip_address"/>
                            <field name="port"/>
                            <field name="config_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <group string="Location">
                            <field name="location"/>
                        </group>
                        <group string="Activity">
                            <field name="last_activity" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Statistics">
                            <field name="total_users" readonly="1"/>
                            <field name="total_transactions" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Add notes about this terminal..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ZKBio Terminal Action -->
    <record id="action_zkbio_terminal" model="ir.actions.act_window">
        <field name="name">Biometric Terminals</field>
        <field name="res_model">zkbio.terminal</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No biometric terminals found
            </p>
            <p>
                Sync terminals from your ZKBio Time API configuration to see them here.
            </p>
        </field>
    </record>
</odoo>
