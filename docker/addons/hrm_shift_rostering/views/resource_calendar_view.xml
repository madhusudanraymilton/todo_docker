<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="shift_code_resource_calendar" model="ir.ui.view">
        <field name="name">shift.code.resource.calendar</field>
        <field name="model">resource.calendar</field>
        <field name="inherit_id" ref="resource.resource_calendar_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='schedule_type']" position="before">
                <field name="shift_code"/>
            </xpath>
        </field>
    </record>
</odoo>
