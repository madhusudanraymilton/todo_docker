<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_announcement" model="ir.ui.view">
        <field name="name">res.users.form.announcement.access</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook/page[@name='access_rights']" position="inside">
                <group string="Announcement Module">
                    <field name="allow_announcement_access"
                           string="Allow Announcement Module Access"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>