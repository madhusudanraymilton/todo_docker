                                <tr>
                                    <td style="text-align: left; width: 33%;">
                                        Generated: <t t-esc="doc.create_date or 'N/A'"/>
                                    </td>
                                    <td style="text-align: center; width: 34%;">
                                        Loan Management System
                                    </td>
                                    <td style="text-align: right; width: 33%;">
                                        Page 1 of 1
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>