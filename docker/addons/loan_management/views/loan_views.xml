<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Loan Form View -->
    <record id="view_hr_loan_form" model="ir.ui.view">
        <field name="name">hr.loan.form</field>
        <field name="model">hr.loan</field>
        <field name="arch" type="xml">
            <form string="Loan">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" 
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" 
                            invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" 
                            invisible="state != 'submitted'"/>
                    <button name="action_pay" string="Pay" type="object" class="btn-primary" 
                            invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,disbursed,partially_paid,paid,rejected"/>
                    <button name="action_print_report" string="Print" type="object" class="btn-secondary" icon="fa-print"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_submit" type="object" class="oe_stat_button" icon="fa-paper-plane" 
                                invisible="state != 'draft'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Submit</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Loan Reference"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" widget="many2one" required="1"/>
                            <field name="partner_id" readonly="1" string="Loan Recipient"/>
                            <field name="department_id"/>
                            <field name="job_position_id"/>
                            <field name="date" required="1"/>
                            <field name="loan_amount" required="1"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="no_of_installments" required="1"/>
                            <field name="installment_amount" readonly="1"/>
                            <field name="payment_start_date" required="1"/>
                            <field name="reason" widget="text" placeholder="Purpose of loan..."/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Accounting" name="accounting">
                            <group>
                                <field name="journal_id"/>
                                <field name="account_debit"/>
                                <field name="account_credit"/>
                                <field name="move_id" widget="many2one" readonly="1"/>
                                <field name="disbursement_date" readonly="1"/>
                            </group>
                        </page>
                        
                        <page string="Installments" name="installments" invisible="state in ['draft', 'submitted', 'rejected']">
                            <field name="loan_line_ids">
                                <list string="Payment Schedule">
                                    <field name="sequence"/>
                                    <field name="due_date"/>
                                    <field name="amount"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'paid'"
                                           decoration-danger="state == 'overdue'"/>
                                    <field name="payment_date"/>
                                    <field name="payslip_id" widget="many2one"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Summary" name="summary">
                            <group>
                                <group>
                                    <label for="total_amount" string="Total Amount"/>
                                    <div>
                                        <field name="total_amount" nolabel="1" readonly="1"/>
                                    </div>
                                </group>
                                <group>
                                    <label for="total_paid" string="Total Paid"/>
                                    <div>
                                        <field name="total_paid" nolabel="1" readonly="1"/>
                                    </div>
                                </group>
                                <group>
                                    <label for="balance_amount" string="Due amount"/>
                                    <div>
                                        <field name="balance_amount" nolabel="1" readonly="1"/>
                                    </div>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Repayments" name="repayments">
                            <field name="repayment_ids">
                                <list string="Repayment History">
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="payment_method"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'paid'"
                                           decoration-danger="state == 'cancelled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>

    </record>
    
    <!-- Loan Tree View -->
    <record id="view_hr_loan_list" model="ir.ui.view">
        <field name="name">hr.loan.list</field>
        <field name="model">hr.loan</field>
        <field name="arch" type="xml">
            <list string="Request for loans">
                <field name="name"/>
                <field name="employee_id" string="Loan Recipient"/>
                <field name="partner_id" string="Accounting Partner"/>
                <field name="date"/>
                <field name="loan_amount"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    
    <!-- Loan Search View -->
    <record id="view_hr_loan_search" model="ir.ui.view">
        <field name="name">hr.loan.search</field>
        <field name="model">hr.loan</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="date"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="submitted" string="Submitted" domain="[('state','=','submitted')]"/>
                <filter name="approved" string="Approved" domain="[('state','=','approved')]"/>
                <filter name="disbursed" string="Disbursed" domain="[('state','=','disbursed')]"/>
                <filter name="paid" string="Paid" domain="[('state','=','paid')]"/>
            </search>
        </field>
    </record>
    
    <!-- Loan Action -->
    <record id="action_hr_loan" model="ir.actions.act_window">
        <field name="name">Request for loans</field>
        <field name="res_model">hr.loan</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_hr_loan_list"/>
        <field name="search_view_id" ref="view_hr_loan_search"/>
        <field name="context">{'default_state': 'draft'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first loan
            </p>
            <p>
                Use this menu to create and manage employee loans.
            </p>
        </field>
    </record>
</odoo>