<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Loan Sequence -->
        <record id="seq_hr_loan" model="ir.sequence">
            <field name="name">Loan Reference</field>
            <field name="code">hr.loan</field>
            <field name="prefix">LOAN/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        
        <!-- Loan Repayment Sequence -->
        <record id="seq_hr_loan_repayment" model="ir.sequence">
            <field name="name">Loan Repayment</field>
            <field name="code">hr.loan.repayment</field>
            <field name="prefix">REPAY/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        
        <!-- Salary Advance Sequence -->
        <record id="seq_hr_salary_advance" model="ir.sequence">
            <field name="name">Salary Advance Reference</field>
            <field name="code">hr.salary.advance</field>
            <field name="prefix">ADV/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>