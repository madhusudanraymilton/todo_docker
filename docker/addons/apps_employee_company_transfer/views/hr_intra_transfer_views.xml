<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_intra_transfer_form" model="ir.ui.view">
        <field name="name">hr.intra.transfer.form</field>
        <field name="model">hr.intra.transfer</field>
        <field name="arch" type="xml">
            <form string="Intra-Company Transfer">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-success"
                            groups="apps_employee_company_transfer.group_transfer_approver"
                            invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Reject" type="object"
                            class="btn-danger"
                            groups="apps_employee_company_transfer.group_transfer_approver"
                            invisible="state not in ('submitted','approved')"/>
                    <button name="action_transfer" string="Transfer" type="object"
                            class="btn-primary"
                            groups="hr.group_hr_manager"
                            invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,transferred"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group string="Employee Information">
                        <group>
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="company_id" readonly="1"/>
                            <field name="from_department_id" readonly="1"/>
                            <field name="from_job_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="transfer_date" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <group string="Transfer Destination">
                        <group>
                            <field name="to_department_id" readonly="state != 'draft'"/>
                            <field name="to_job_id" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="supervisor_id" readonly="state != 'draft'"/>
                            <field name="reporting_head_id" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <group string="Rejection Details" invisible="state != 'rejected'">
                        <field name="rejection_reason" nolabel="1"/>
                    </group>

                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Add any additional notes here..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_intra_transfer_list" model="ir.ui.view">
        <field name="name">hr.intra.transfer.list</field>
        <field name="model">hr.intra.transfer</field>
        <field name="arch" type="xml">
            <list string="Intra-Company Transfers"
                  decoration-success="state == 'transferred'"
                  decoration-info="state in ('submitted','approved')"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="company_id"/>
                <field name="from_department_id"/>
                <field name="to_department_id"/>
                <field name="from_job_id" optional="hide"/>
                <field name="to_job_id" optional="hide"/>
                <field name="transfer_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'transferred'"
                       decoration-info="state in ('submitted','approved')"
                       decoration-danger="state == 'rejected'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

   

    <record id="action_hr_intra_transfer" model="ir.actions.act_window">
        <field name="name">Intra Company Transfers</field>
        <field name="res_model">hr.intra.transfer</field>
        <field name="view_mode">list,form</field>
        
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first intra-company transfer</p>
            <p>Manage employee transfers within the same company.</p>
        </field>
    </record>

</odoo>
