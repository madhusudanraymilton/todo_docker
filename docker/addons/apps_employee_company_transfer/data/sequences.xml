<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for Inter-Company Transfer -->
        <record id="seq_hr_company_transfer" model="ir.sequence">
            <field name="name">Inter-Company Transfer</field>
            <field name="code">hr.company.transfer</field>
            <field name="prefix">ICT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Intra-Company Transfer -->
        <record id="seq_hr_intra_transfer" model="ir.sequence">
            <field name="name">Intra-Company Transfer</field>
            <field name="code">hr.intra.transfer</field>
            <field name="prefix">IRT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
