    <record id="action_festival_bonus_run" model="ir.actions.act_window">
        <field name="name">Festival Bonus</field>
        <field name="res_model">festival.bonus.wizard</field>
        <field name="view_mode">form,kanban</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_festival_bonus_wizard_form"/>
        <field name="context">{'dialog_size': 'medium'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No Festival Bonus Pay Runs yet.</p>
            <p>
                <a name="%(action_festival_bonus_wizard)d" type="action" class="btn btn-primary">
                    Create Festival Bonus
                </a>
            </p>
        </field>
    </record>

    <!-- Submenu -->
    <menuitem id="menu_hr_payroll_festival_bonus" name="Festival Bonus" parent="hr_payroll.menu_hr_payroll_payslips" action="action_festival_bonus_run" sequence="90" groups="hr_payroll.group_hr_payroll_user"/>

